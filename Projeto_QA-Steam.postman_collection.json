  "item": [
    {
      "name": "Consultar-Jogos-possuidos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\" TC-001 - Caminho Feliz: Validar formato do tempo de jogo\", function() {",
              "    var jsonData = pm.response.json();",
              "    var games = jsonData.response.games;",
              "",
              "    // Se o usuário não tiver jogos, o teste passa sem validar o formato",
              "    if (!games || games.length === 0) { return; }",
              "",
              "    var primeirojogo = games[0];",
              "",
              "    // vendo se existe playtime forever no primeiro jogo",
              "    pm.expect(primeirojogo).to.have.property('playtime_forever');",
              "    // vendo se o formato do campo playtime forever está correto",
              "    pm.expect(primeirojogo.playtime_forever).to.be.a('number');",
              "",
              "    // As horas não podem ser negativas",
              "    pm.expect(primeirojogo.playtime_forever).to.be.at.least(0);",
              "});",
              "",
              "pm.test(\"TC-002 - Caminho Feliz: Retorno com sucesso e lista de jogos\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.response.to.have.status(200);",
              "    pm.expect(jsonData.response).to.have.property('games');",
              "    pm.expect(jsonData.response.game_count).to.be.a('number').and.to.be.at.least(0);",
              "});",
              "",
              "// Jogos gratuitos não devem estar na lista de jogos do usuário. Exemplo: Dota 2 (appid: 570) sem o parametro",
              "pm.test(\"TC-003 - Caminho Feliz: Validar se jogo gratuito (Dota 2) não está na lista\", function () {",
              "    var jsonData = pm.response.json();",
              "    var games = jsonData.response.games;",
              "",
              "    var encontrouJogo = games.find(game => game.appid === 570);",
              "",
              "    pm.expect(encontrouJogo).to.be.undefined;",
              "});",
              "",
              "pm.test(\"TC-004 - Caminho Feliz: Validar se a contagem de jogos bate com a lista\", function () {",
              "    var jsonData = pm.response.json();",
              "    var contagemDeclarada = jsonData.response.game_count;",
              "    var tamanhoRealDaLista = jsonData.response.games.length;",
              "",
              "    pm.expect(tamanhoRealDaLista).to.eql(contagemDeclarada);",
              "});",
              "",
              "pm.test(\"TC-005 - Caminho Triste: Validar bloqueio com chave inválida\", function () {",
              "    // 1. O Status Code NÃO pode ser 200",
              "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
              "",
              "    // 2. Validar a mensagem amigável de erro (se houver)",
              "    // Algumas APIs retornam JSON de erro, outras apenas o status.",
              "    console.log(\"Status recebido: \" + pm.response.status);",
              "});",
              "",
              "pm.test(\"TC-006 - Caminho Triste: Validar resposta para SteamID em formato de texto\", function () {",
              "    var responseCode = pm.response.code;",
              "",
              "    pm.expect(responseCode).to.be.below(500);",
              "",
              "    // Verificamos se ele barrou a requisição ou se apenas retornou vazio",
              "    if (responseCode === 400) {",
              "        console.log(\"Sucesso: A API validou o erro de formato (Bad Request).\");",
              "    } else if (responseCode === 200) {",
              "        var jsonData = pm.response.json();",
              "        // Se retornar 200, a resposta deve vir sem a lista de jogos",
              "        pm.expect(jsonData.response).to.not.have.property('games');",
              "        console.log(\"A API aceitou o texto, mas não retornou dados de jogos.\");",
              "    }",
              "});",
              "",
              "pm.test(\"TC-007 - Caminho Triste: Validar bloqueio de método HTTP não permitido\", function () {",
              "    // Esperamos que o servidor barre métodos diferentes de GET",
              "    pm.expect(pm.response.code).to.equal(405);",
              "    console.log(\"Servidor barrou corretamente o método não permitido.\");",
              "});",
              "",
              "pm.test(\"TC-008 - Caminho Triste: Validar resiliência com parâmetros de filtro inválidos\", function () {",
              "    // O servidor deve tratar o erro ou ignorar, mas nunca retornar 500",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
              "",
              "    if(pm.response.code === 200) {",
              "        var jsonData = pm.response.json();",
              "        // Se enviamos um valor doido no include_appinfo,",
              "        // validamos se ele NÃO retornou o nome do jogo (comportamento padrão de erro)",
              "        pm.expect(jsonData.response.games[0]).to.not.have.property('name');",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let currentId = pm.environment.get(\"steam_id\");",
              "",
              "// Regra: SteamID64 deve ter exatamente 17 dígitos",
              "if (currentId && currentId.length !== 17) {",
              "    console.error(\"ABORTANDO: O SteamID fornecido é inválido (não tem 17 dígitos).\");",
              "",
              "    // Forçar um erro proposital para não gastar sua cota de API à toa",
              "    throw new Error(\"SteamID inválido detectado no Pre-request.\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
