      "name": "New Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"TC-009 - Caminho Feliz: Nome do Persona 4\", function(){",
              "    var resposta = pm.response.json();",
              "    var games = resposta.response.games;",
              "    var achou = games.some(g => g.name === \"Persona 4 Golden\");",
              "",
              "    pm.expect(achou).to.eql(true);",
              "});",
              "",
              "pm.test(\"TC-010 - Caminho Feliz: Tempo de jogo total do Resident Evil 4\", function(){",
              "    var resposta = pm.response.json();",
              "    var games = resposta.response.games;",
              "    var achou = games.find(g => g.name === \"Resident Evil 4\");",
              "",
              "    pm.expect(achou.playtime_forever).to.eql(4046);",
              "});",
              "",
              "pm.test(\"TC-011 - Caminho Feliz: Conferir se o url do icone da imagem do Kingdom Come esta certo\", function(){",
              "    var resposta = pm.response.json();",
              "    var games = resposta.response.games;",
              "    var achou = games.find(g => g.name === \"Kingdom Come: Deliverance\");",
              "",
              "    pm.expect(achou.img_icon_url).to.eql(\"915ec515c36645855abed0476b5b0891d8a4e47a\");",
              "});",
              "",
              "pm.test(\"TC-012 - Caminho Triste: Simulando o valor errado do ID de Persona 4\", function(){",
              "    var resposta = pm.response.json();",
              "    var games = resposta.response.games;",
              "    var achou = games.find(g => g.name === \"Persona 4 Golden\");",
              "",
              "    achou.appid = 0; // colocando o valor de appid do persona 4 igual a 0",
              "",
              "    pm.expect(achou.appid).to.eql(1113000);",
              "});",
              "",
              "pm.test(\"TC-013 - Caminho Triste: Simulando o tempo de jogo Rain World igual a 0 no Linux\", function(){",
              "    var resposta = pm.response.json();",
              "    var games = resposta.response.games;",
              "    var achou = games.find(g => g.name === \"Rain World\");",
              "",
              "    achou.playtime_linux_forever = 0; // colocando o valor linux playtime igual a 0",
              "",
              "    pm.expect(achou.playtime_linux_forever).to.eql(119);",
              "});",
              "",
              "pm.test(\"TC-014 - Caminho Triste: Simular o total_count = 10, em vez de 8\", function() {",
              "    var resposta = pm.response.json();",
              "    var total = resposta.response.total_count = 10; // colocando o valor total_count igual a 10",
              "",
              "    pm.expect(total).to.eql(8);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
