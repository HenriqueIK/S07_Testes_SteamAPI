  },
  "item": [
    {
      "name": "New Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"TC-009 - Caminho Feliz: Todos os jogos recentes têm playtime_2weeks maior que zero\", function () {",
              "    var games = pm.response.json().response.games;",
              "    if (!games || games.length === 0) { return; }",
              "    games.forEach(function(game) {",
              "        pm.expect(game).to.have.property('playtime_2weeks');",
              "        pm.expect(game.playtime_2weeks).to.be.above(0);",
              "    });",
              "});",
              "",
              "pm.test(\"TC-010 - Caminho Feliz: total_count é consistente com o tamanho da lista retornada\", function () {",
              "    var resposta = pm.response.json().response;",
              "    var total = resposta.total_count;",
              "    var tamanho = resposta.games ? resposta.games.length : 0;",
              "    pm.expect(tamanho).to.eql(total);",
              "});",
              "",
              "pm.test(\"TC-011 - Caminho Feliz: img_icon_url de cada jogo é um hash hex válido de 40 caracteres\", function () {",
              "    var games = pm.response.json().response.games;",
              "    if (!games || games.length === 0) { return; }",
              "    games.forEach(function(game) {",
              "        pm.expect(game.img_icon_url).to.match(/^[a-f0-9]{40}$/);",
              "    });",
              "});",
              "",
              "pm.test(\"TC-012 - Caminho Triste: Simular playtime_2weeks zerado em jogo recente\", function () {",
              "    var games = pm.response.json().response.games || [{ playtime_2weeks: 0 }];",
              "    games[0].playtime_2weeks = 0;",
              "    pm.expect(games[0].playtime_2weeks).to.be.above(0);",
              "});",
              "",
              "pm.test(\"TC-013 - Caminho Triste: Simular total_count incorreto\", function () {",
              "    var resposta = pm.response.json().response;",
              "    resposta.total_count = 999;",
              "    pm.expect(resposta.total_count).to.eql(resposta.games ? resposta.games.length : 0);",
              "});",
              "",
              "pm.test(\"TC-014 - Caminho Triste: Simular img_icon_url com formato inválido\", function () {",
              "    var games = pm.response.json().response.games || [{ img_icon_url: \"\" }];",
              "    games[0].img_icon_url = \"nao-e-um-hash-valido\";",
              "    pm.expect(games[0].img_icon_url).to.match(/^[a-f0-9]{40}$/);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
