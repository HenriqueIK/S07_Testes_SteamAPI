  "item": [
    {
      "name": "GetPlayerSummaries",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TC-015: Valida que o retorno contém a lista de players com ao menos 1 jogador",
              "pm.test(\"TC-015: Valida que o retorno contém a lista de players com ao menos 1 jogador\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.response.players).to.be.an(\"array\").with.lengthOf.at.least(1);",
              "});",
              "",
              "// TC-016: Valida que os campos obrigatórios do perfil existem",
              "pm.test(\"TC-016: Valida que os campos obrigatórios do perfil existem (steamid, personaname, profileurl, avatar)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var player = jsonData.response.players[0];",
              "    pm.expect(player).to.have.property(\"steamid\");",
              "    pm.expect(player).to.have.property(\"personaname\");",
              "    pm.expect(player).to.have.property(\"profileurl\");",
              "    pm.expect(player).to.have.property(\"avatar\");",
              "});",
              "",
              "// TC-017: Valida que o communityvisibilitystate é um número válido (1, 2 ou 3)",
              "pm.test(\"TC-017: Valida que o communityvisibilitystate é um número válido (1, 2 ou 3)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var player = jsonData.response.players[0];",
              "    pm.expect([1, 2, 3]).to.include(player.communityvisibilitystate);",
              "});",
              "",
              "// TC-018: Simula que o personaname retornado é diferente do esperado (caminho triste de validação de dado)",
              "pm.test(\"TC-018: Simula que o personaname retornado é diferente do esperado\", function () {",
              "    var jsonData = pm.response.json();",
              "    var player = jsonData.response.players[0];",
              "    player.personaname = \"NomeErrado\";",
              "    pm.expect(player.personaname).to.eql(\"SeuNomeReal\");",
              "});",
              "",
              "// TC-019: Simula que o communityvisibilitystate é 1 (privado) quando deveria ser 3 (público)",
              "pm.test(\"TC-019: Simula que o communityvisibilitystate é 1 (privado) quando deveria ser 3 (público)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var player = jsonData.response.players[0];",
              "    player.communityvisibilitystate = 1;",
              "    pm.expect(player.communityvisibilitystate).to.eql(3);",
              "});",
              "",
              "// TC-020: Simula que a lista de players está vazia quando deveria ter jogadores",
              "pm.test(\"TC-020: Simula que a lista de players está vazia quando deveria ter jogadores\", function () {",
              "    var jsonData = pm.response.json();",
              "    var players = jsonData.response.players;",
              "    // Força a lista como vazia para simular ausência de jogadores",
              "    players = [];",
              "    pm.expect(players).to.have.lengthOf.at.least(1);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
